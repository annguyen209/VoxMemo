<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VoxMemo.ViewModels"
             xmlns:views="using:VoxMemo.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="700"
             x:Class="VoxMemo.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer>
        <StackPanel Margin="32,24" Spacing="20" MaxWidth="680">
            <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Foreground="#cdd6f4"/>

            <!-- Status -->
            <Border Background="#313244" CornerRadius="8" Padding="14,10"
                    IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="#fab387"/>
            </Border>

            <!-- AI Provider -->
            <Border Background="#1e1e2e" CornerRadius="12" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="AI Provider" FontSize="18" FontWeight="SemiBold" Foreground="#cdd6f4"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Provider" FontSize="12" Foreground="#6c7086"/>
                        <ComboBox ItemsSource="{Binding AiProviders}"
                                  SelectedItem="{Binding SelectedAiProvider}"
                                  HorizontalAlignment="Stretch"
                                  Background="#313244" Foreground="#cdd6f4"
                                  CornerRadius="6" Padding="12,8"/>
                    </StackPanel>

                    <!-- Ollama Settings -->
                    <StackPanel Spacing="12"
                                IsVisible="{Binding SelectedAiProvider, Converter={x:Static views:SettingsView.IsOllamaConverter}}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Ollama URL" FontSize="12" Foreground="#6c7086"/>
                            <TextBox Text="{Binding OllamaUrl}"
                                     Background="#313244" Foreground="#cdd6f4"
                                     CornerRadius="6" Padding="12,8"/>
                        </StackPanel>
                        <Button Content="Test Connection"
                                Command="{Binding TestOllamaConnectionCommand}"
                                Background="#89b4fa" Foreground="#1e1e2e"
                                CornerRadius="8" Padding="16,8"/>
                    </StackPanel>

                    <!-- OpenAI / Compatible Settings -->
                    <StackPanel Spacing="12"
                                IsVisible="{Binding SelectedAiProvider, Converter={x:Static views:SettingsView.IsOpenAiConverter}}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Base URL" FontSize="12" Foreground="#6c7086"/>
                            <TextBox Text="{Binding OpenAiBaseUrl}"
                                     Background="#313244" Foreground="#cdd6f4"
                                     CornerRadius="6" Padding="12,8"
                                     Watermark="https://api.openai.com/v1"/>
                            <TextBlock Text="LM Studio: localhost:1234/v1  |  LocalAI: localhost:8080/v1  |  vLLM: localhost:8000/v1"
                                       FontSize="11" Foreground="#7f849c" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="API Key (optional for local servers)" FontSize="12" Foreground="#6c7086"/>
                            <TextBox Text="{Binding OpenAiApiKey}"
                                     PasswordChar="*"
                                     Background="#313244" Foreground="#cdd6f4"
                                     CornerRadius="6" Padding="12,8"
                                     Watermark="sk-..."/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Anthropic Settings -->
                    <StackPanel Spacing="6"
                                IsVisible="{Binding SelectedAiProvider, Converter={x:Static views:SettingsView.IsAnthropicConverter}}">
                        <TextBlock Text="API Key" FontSize="12" Foreground="#6c7086"/>
                        <TextBox Text="{Binding AnthropicApiKey}"
                                 PasswordChar="*"
                                 Background="#313244" Foreground="#cdd6f4"
                                 CornerRadius="6" Padding="12,8"
                                 Watermark="sk-ant-..."/>
                    </StackPanel>

                    <!-- Model Selection -->
                    <Border Background="#313244" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <DockPanel>
                                <TextBlock Text="AI Model" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#cdd6f4" VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Content="Refresh"
                                        Command="{Binding RefreshAiModelsCommand}"
                                        Background="#45475a" Foreground="#cdd6f4"
                                        CornerRadius="6" Padding="12,5"
                                        HorizontalAlignment="Right" FontSize="12"/>
                            </DockPanel>
                            <ComboBox ItemsSource="{Binding AvailableAiModels}"
                                      SelectedItem="{Binding SelectedAiModel}"
                                      HorizontalAlignment="Stretch"
                                      Background="#1e1e2e" Foreground="#cdd6f4"
                                      CornerRadius="6" Padding="12,8">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Timeout -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="AI Timeout" FontSize="12" Foreground="#bac2de"
                                   VerticalAlignment="Center"/>
                        <NumericUpDown Value="{Binding AiTimeoutMinutes}"
                                       Minimum="1" Maximum="60" Increment="1"
                                       Background="#313244" Foreground="#cdd6f4"
                                       CornerRadius="6" Padding="8,4"
                                       Width="100"/>
                        <TextBlock Text="minutes" FontSize="12" Foreground="#7f849c"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Whisper Transcription -->
            <Border Background="#1e1e2e" CornerRadius="12" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="Transcription (Whisper)" FontSize="18" FontWeight="SemiBold" Foreground="#cdd6f4"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Active Model" FontSize="12" Foreground="#6c7086"/>
                        <ComboBox ItemsSource="{Binding AvailableWhisperModels}"
                                  SelectedItem="{Binding SelectedWhisperModel}"
                                  HorizontalAlignment="Stretch"
                                  Background="#313244" Foreground="#cdd6f4"
                                  CornerRadius="6" Padding="12,8"/>
                        <TextBlock Text="Recommended: tiny for speed, large-v3-turbo for best quality (especially non-English languages like Vietnamese, Chinese, Japanese). Turbo is 6x faster than large-v3 with similar accuracy."
                                   FontSize="11" Foreground="#7f849c" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Download Model" FontSize="12" Foreground="#6c7086"/>
                        <WrapPanel Orientation="Horizontal">
                            <WrapPanel.Styles>
                                <Style Selector="Button">
                                    <Setter Property="Margin" Value="0,0,8,8"/>
                                    <Setter Property="Background" Value="#313244"/>
                                    <Setter Property="Foreground" Value="#cdd6f4"/>
                                    <Setter Property="CornerRadius" Value="6"/>
                                    <Setter Property="Padding" Value="14,7"/>
                                    <Setter Property="FontSize" Value="12"/>
                                </Style>
                            </WrapPanel.Styles>
                            <Button Content="tiny (~75MB)"
                                    Command="{Binding DownloadWhisperModelCommand}"
                                    CommandParameter="tiny"/>
                            <Button Content="base (~150MB)"
                                    Command="{Binding DownloadWhisperModelCommand}"
                                    CommandParameter="base"/>
                            <Button Content="small (~500MB)"
                                    Command="{Binding DownloadWhisperModelCommand}"
                                    CommandParameter="small"/>
                            <Button Content="medium (~1.5GB)"
                                    Command="{Binding DownloadWhisperModelCommand}"
                                    CommandParameter="medium"/>
                            <Button Content="large-v3-turbo (~800MB)"
                                    Command="{Binding DownloadWhisperModelCommand}"
                                    CommandParameter="large-v3-turbo"
                                    Background="#cba6f7" Foreground="#1e1e2e"/>
                            <Button Content="large-v3 (~3GB)"
                                    Command="{Binding DownloadWhisperModelCommand}"
                                    CommandParameter="large-v3"/>
                        </WrapPanel>
                        <TextBlock Text="{Binding DownloadProgress}" FontSize="12" Foreground="#a6e3a1"
                                   IsVisible="{Binding IsDownloadingModel}"/>
                    </StackPanel>

                    <!-- Custom models -->
                    <Border Height="1" Background="#313244" Margin="0,4"/>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Custom Models" FontSize="13" FontWeight="SemiBold" Foreground="#cdd6f4"/>
                        <TextBlock Text="Drop any ggml-format .bin file into the models folder. Name it ggml-yourname.bin and it will appear in the dropdown above."
                                   FontSize="11" Foreground="#7f849c" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Open Models Folder"
                                    Command="{Binding OpenModelsFolderCommand}"
                                    Background="#313244" Foreground="#cdd6f4"
                                    CornerRadius="6" Padding="14,7" FontSize="12"/>
                            <Button Content="Import Model File"
                                    Command="{Binding ImportModelCommand}"
                                    Background="#313244" Foreground="#cdd6f4"
                                    CornerRadius="6" Padding="14,7" FontSize="12"/>
                            <Button Content="Refresh"
                                    Command="{Binding RefreshWhisperModelsCommand}"
                                    Background="#313244" Foreground="#cdd6f4"
                                    CornerRadius="6" Padding="14,7" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Automation -->
            <Border Background="#1e1e2e" CornerRadius="12" Padding="24">
                <StackPanel Spacing="14">
                    <TextBlock Text="Automation" FontSize="18" FontWeight="SemiBold" Foreground="#cdd6f4"/>
                    <CheckBox IsChecked="{Binding AutoTranscribe}" Foreground="#cdd6f4">
                        <TextBlock Text="Auto-transcribe after recording stops" FontSize="13"/>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding AutoSummarize}" Foreground="#cdd6f4">
                        <TextBlock Text="Auto-summarize after transcription completes" FontSize="13"/>
                    </CheckBox>
                    <TextBlock Text="When enabled, recordings are automatically processed using the configured Whisper model and AI provider."
                               FontSize="11" Foreground="#7f849c" TextWrapping="Wrap"/>

                    <Border Height="1" Background="#313244" Margin="0,4"/>
                    <CheckBox IsChecked="{Binding SmartProcessSkipDialog}" Foreground="#cdd6f4">
                        <TextBlock Text="Smart Process: skip step selection dialog" FontSize="13"/>
                    </CheckBox>
                    <TextBlock Text="When checked, Smart Process runs with previously selected steps without showing the dialog. Uncheck to reset."
                               FontSize="11" Foreground="#7f849c" TextWrapping="Wrap"/>

                    <Border Height="1" Background="#313244" Margin="0,4"
                            IsVisible="{Binding IsGlobalHotkeySupported}"/>
                    <StackPanel Spacing="6" IsVisible="{Binding IsGlobalHotkeySupported}">
                        <TextBlock Text="Recording Hotkey" FontSize="12" Foreground="#bac2de"/>
                        <TextBox Text="{Binding RecordingHotkey}"
                                 Background="#313244" Foreground="#cdd6f4"
                                 CornerRadius="6" Padding="12,8"
                                 Watermark="Ctrl+Shift+R"/>
                        <TextBlock Text="Global hotkey to start/stop recording. Use format: Ctrl+Shift+R, Alt+F9, etc."
                                   FontSize="11" Foreground="#7f849c" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Custom Prompts -->
            <Border Background="#1e1e2e" CornerRadius="12" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="Custom AI Prompts" FontSize="18" FontWeight="SemiBold" Foreground="#cdd6f4"/>
                    <TextBlock Text="Override the built-in prompts for Summary and Identify Speakers. Leave empty to use defaults. The language instruction is appended automatically."
                               FontSize="11" Foreground="#7f849c" TextWrapping="Wrap"/>

                    <StackPanel Spacing="6">
                        <DockPanel>
                            <TextBlock Text="Summary Prompt" FontSize="12" Foreground="#bac2de"
                                       VerticalAlignment="Center"/>
                            <ComboBox DockPanel.Dock="Right"
                                      ItemsSource="{Binding SummaryTemplates}"
                                      SelectedItem="{Binding SelectedSummaryTemplate}"
                                      Background="#313244" Foreground="#cdd6f4"
                                      CornerRadius="6" Padding="8,4" FontSize="11"
                                      MinWidth="180" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <TextBox Text="{Binding CustomSummaryPrompt}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="80" MaxHeight="160"
                                 Background="#313244" Foreground="#cdd6f4"
                                 CornerRadius="6" Padding="12,8"
                                 Watermark="Leave empty for default"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <DockPanel>
                            <TextBlock Text="Identify Speakers Prompt" FontSize="12" Foreground="#bac2de"
                                       VerticalAlignment="Center"/>
                            <ComboBox DockPanel.Dock="Right"
                                      ItemsSource="{Binding SpeakerTemplates}"
                                      SelectedItem="{Binding SelectedSpeakerTemplate}"
                                      Background="#313244" Foreground="#cdd6f4"
                                      CornerRadius="6" Padding="8,4" FontSize="11"
                                      MinWidth="180" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <TextBox Text="{Binding CustomSpeakerPrompt}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="80" MaxHeight="160"
                                 Background="#313244" Foreground="#cdd6f4"
                                 CornerRadius="6" Padding="12,8"
                                 Watermark="Leave empty for default"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- General -->
            <Border Background="#1e1e2e" CornerRadius="12" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="General" FontSize="18" FontWeight="SemiBold" Foreground="#cdd6f4"/>

                    <!-- Languages -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Languages" FontSize="14" FontWeight="SemiBold" Foreground="#cdd6f4"/>

                        <!-- Enabled languages -->
                        <TextBlock Text="Enabled languages (used in Recording)" FontSize="12" Foreground="#bac2de"/>
                        <ItemsControl ItemsSource="{Binding EnabledLanguages}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#313244" CornerRadius="6" Padding="10,6" Margin="0,0,6,6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding}" FontSize="12" Foreground="#cdd6f4"
                                                       VerticalAlignment="Center"/>
                                            <Button Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).RemoveLanguageCommand}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" Foreground="#f38ba8"
                                                    Padding="4,0" FontSize="11" VerticalAlignment="Center">
                                                <TextBlock Text="x"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Add language -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ComboBox ItemsSource="{Binding AllLanguages}"
                                      SelectedItem="{Binding SelectedAvailableLanguage}"
                                      Background="#313244" Foreground="#cdd6f4"
                                      CornerRadius="6" Padding="10,6" MinWidth="200"/>
                            <Button Content="Add"
                                    Command="{Binding AddLanguageCommand}"
                                    Background="#89b4fa" Foreground="#1e1e2e"
                                    CornerRadius="6" Padding="14,6" FontSize="12"/>
                        </StackPanel>

                        <!-- Default language -->
                        <StackPanel Spacing="6" Margin="0,6,0,0">
                            <TextBlock Text="Default Language" FontSize="12" Foreground="#bac2de"/>
                            <ComboBox ItemsSource="{Binding EnabledLanguageCodes}"
                                      SelectedItem="{Binding DefaultLanguage}"
                                      HorizontalAlignment="Stretch"
                                      Background="#313244" Foreground="#cdd6f4"
                                      CornerRadius="6" Padding="12,8"/>
                        </StackPanel>
                    </StackPanel>

                    <CheckBox IsChecked="{Binding StartWithWindows}" Foreground="#cdd6f4"
                              IsVisible="{Binding IsStartupSupported}">
                        <TextBlock Text="{Binding StartupLabel}" FontSize="13"/>
                    </CheckBox>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Storage Location" FontSize="12" Foreground="#6c7086"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Browse..."
                                    x:Name="BrowseStorageButton"
                                    Click="OnBrowseStoragePath"
                                    Background="#313244" Foreground="#cdd6f4"
                                    CornerRadius="0,6,6,0" Padding="16,8"
                                    Margin="0"/>
                            <TextBox Text="{Binding StoragePath}"
                                     Background="#313244" Foreground="#cdd6f4"
                                     CornerRadius="6,0,0,6" Padding="12,8"/>
                        </DockPanel>
                        <TextBlock Text="Recordings and data will be stored in this folder"
                                   FontSize="11" Foreground="#7f849c"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
