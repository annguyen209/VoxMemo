<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VoxMemo.ViewModels"
             xmlns:views="using:VoxMemo.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="VoxMemo.Views.MeetingsView"
             x:DataType="vm:MeetingsViewModel">

    <Grid ColumnDefinitions="300,*">
        <!-- Meeting List -->
        <Border Grid.Column="0" Background="#1e1e2e" Padding="0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,12">
                    <DockPanel>
                        <TextBlock Text="Meetings" FontSize="20" FontWeight="Bold" Foreground="#cdd6f4"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding MeetingCount}"
                                   FontSize="12" Foreground="#7f849c"
                                   VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                   Margin="0,0,0,2"/>
                    </DockPanel>
                    <TextBox Text="{Binding SearchText}"
                             Watermark="Search meetings..."
                             Margin="0,12,0,0"
                             Background="#313244" Foreground="#cdd6f4"
                             CornerRadius="6" Padding="12,8"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="16,8,16,16">
                    <Grid ColumnDefinitions="*,8,*">
                        <Button Grid.Column="0" Content="+ From Audio"
                                Command="{Binding CreateMeetingCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="12,8"
                                Background="#cba6f7" Foreground="#1e1e2e"
                                CornerRadius="8" FontWeight="SemiBold"/>
                        <Button Grid.Column="2" Content="+ From Text"
                                Command="{Binding CreateFromTextCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="12,8"
                                Background="#89b4fa" Foreground="#1e1e2e"
                                CornerRadius="8" FontWeight="SemiBold"/>
                    </Grid>
                    <Button Content="Refresh"
                            Command="{Binding LoadMeetingsCommand}"
                            HorizontalAlignment="Stretch"
                            Padding="12,8"
                            Background="#313244" Foreground="#cdd6f4"
                            CornerRadius="8"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Meetings}"
                         SelectedItem="{Binding SelectedMeeting}"
                         Background="Transparent"
                         Margin="8,0">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="Foreground" Value="#cdd6f4"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="Background" Value="#313244"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:MeetingItemViewModel">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding StartedAt, StringFormat='{}{0:MMM dd, yyyy HH:mm}'}"
                                               FontSize="11" Foreground="#bac2de"/>
                                    <TextBlock Text="{Binding Duration}"
                                               FontSize="11" Foreground="#bac2de"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                    <Border Background="#f9e2af" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="{Binding Language}" FontSize="10" FontWeight="Bold" Foreground="#1e1e2e"/>
                                    </Border>
                                    <Border Background="#89b4fa" CornerRadius="4" Padding="6,2"
                                            IsVisible="{Binding HasTranscript}">
                                        <TextBlock Text="T" FontSize="10" FontWeight="Bold" Foreground="#1e1e2e"/>
                                    </Border>
                                    <Border Background="#a6e3a1" CornerRadius="4" Padding="6,2"
                                            IsVisible="{Binding HasSummary}">
                                        <TextBlock Text="S" FontSize="10" FontWeight="Bold" Foreground="#1e1e2e"/>
                                    </Border>
                                    <Border Background="#585b70" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="{Binding Platform}" FontSize="10" Foreground="#cdd6f4"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Meeting Detail -->
        <Border Grid.Column="1">
            <Panel>
                <!-- Empty State -->
                <StackPanel IsVisible="{Binding SelectedMeeting, Converter={x:Static ObjectConverters.IsNull}}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <TextBlock Text="No meeting selected" FontSize="20" Foreground="#7f849c"
                               HorizontalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock Text="Select a meeting from the list or create a new one"
                               FontSize="13" Foreground="#6c7086"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Detail View -->
                <DockPanel IsVisible="{Binding $parent[UserControl].((vm:MeetingsViewModel)DataContext).SelectedMeeting, Converter={x:Static ObjectConverters.IsNotNull}}"
                           DataContext="{Binding SelectedMeeting}"
                           x:DataType="vm:MeetingItemViewModel">

                    <!-- Header Bar -->
                    <Border DockPanel.Dock="Top" Background="#11111b" Padding="24,16">
                        <DockPanel>
                            <!-- Delete button -->
                            <Button DockPanel.Dock="Right"
                                    Command="{Binding $parent[UserControl].((vm:MeetingsViewModel)DataContext).DeleteMeetingCommand}"
                                    CommandParameter="{Binding}"
                                    IsEnabled="{Binding !Detail.IsBusy}"
                                    Background="#45475a" Foreground="#f38ba8"
                                    CornerRadius="6" Padding="14,6"
                                    VerticalAlignment="Center">
                                <TextBlock Text="Delete" FontSize="12" FontWeight="SemiBold"/>
                            </Button>

                            <StackPanel Spacing="4">
                                <TextBox Text="{Binding Title}"
                                         FontSize="20" FontWeight="Bold"
                                         Foreground="#cdd6f4"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         Watermark="Meeting title..."
                                         LostFocus="OnTitleLostFocus"
                                         KeyDown="OnTitleKeyDown"/>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding Platform}" FontSize="12" Foreground="#bac2de"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Duration}" FontSize="12" Foreground="#bac2de"
                                               VerticalAlignment="Center"/>
                                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                              SelectedItem="{Binding Language}"
                                              Background="#313244" Foreground="#cdd6f4"
                                              CornerRadius="4" Padding="6,2" FontSize="11"
                                              MinWidth="60" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding StartedAt, StringFormat='{}{0:MMM dd, yyyy HH:mm}'}"
                                               FontSize="12" Foreground="#bac2de"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Status -->
                    <Border DockPanel.Dock="Top" Padding="24,8"
                            IsVisible="{Binding Detail.StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding Detail.StatusMessage}"
                                   FontSize="13" Foreground="#fab387"/>
                    </Border>

                    <!-- Content area -->
                    <ScrollViewer>
                        <StackPanel Margin="24,12,24,24" Spacing="16">

                            <!-- No Audio notice -->
                            <Border Background="#1e1e2e" CornerRadius="10" Padding="16,12"
                                    IsVisible="{Binding !HasAudio}">
                                <TextBlock Text="No audio file — this meeting was imported from text."
                                           FontSize="12" Foreground="#7f849c"/>
                            </Border>

                            <!-- Audio Player -->
                            <Border Background="#1e1e2e" CornerRadius="10" Padding="16,12"
                                    IsVisible="{Binding HasAudio}">
                                <StackPanel Spacing="12">
                                    <DockPanel>
                                        <TextBlock Text="Audio Player" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#a6adc8" VerticalAlignment="Center"/>
                                        <Button DockPanel.Dock="Right"
                                                Command="{Binding Detail.ExportAudioCommand}"
                                                Background="#313244" Foreground="#bac2de"
                                                CornerRadius="6" Padding="10,4" FontSize="11"
                                                HorizontalAlignment="Right">
                                            <TextBlock Text="Export Audio"/>
                                        </Button>
                                    </DockPanel>

                                    <!-- Seek Slider -->
                                    <Slider Minimum="0"
                                            Maximum="{Binding Playback.PlaybackTotalSeconds}"
                                            Value="{Binding Playback.PlaybackCurrentSeconds}"
                                            IsEnabled="{Binding Playback.IsPlaybackActive}"
                                            x:Name="SeekSlider"
                                            Foreground="#cba6f7"
                                            Background="#313244"/>

                                    <!-- Controls + Time -->
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding Playback.PlaybackPosition}"
                                                   FontSize="12" Foreground="#a6adc8"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Consolas, Courier New"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Button Command="{Binding Playback.PlayAudioCommand}"
                                                    IsEnabled="{Binding !Playback.IsPlaying}"
                                                    Background="#cba6f7" Foreground="#1e1e2e"
                                                    CornerRadius="6" Padding="14,6" MinWidth="64">
                                                <TextBlock Text="Play" FontSize="12" FontWeight="SemiBold"/>
                                            </Button>
                                            <Button Command="{Binding Playback.PauseAudioCommand}"
                                                    IsEnabled="{Binding Playback.IsPlaying}"
                                                    Background="#fab387" Foreground="#1e1e2e"
                                                    CornerRadius="6" Padding="14,6" MinWidth="64">
                                                <TextBlock Text="Pause" FontSize="12" FontWeight="SemiBold"/>
                                            </Button>
                                            <Button Command="{Binding Playback.StopAudioCommand}"
                                                    IsEnabled="{Binding Playback.IsPlaybackActive}"
                                                    Background="#eba0ac" Foreground="#1e1e2e"
                                                    CornerRadius="6" Padding="14,6" MinWidth="64">
                                                <TextBlock Text="Stop" FontSize="12" FontWeight="SemiBold"/>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <!-- Processing indicator -->
                            <Border Background="#313244" CornerRadius="8" Padding="12,8"
                                    IsVisible="{Binding Detail.IsBusy}">
                                <TextBlock Text="Processing in background... new jobs will be queued."
                                           FontSize="12" Foreground="#cba6f7"/>
                            </Border>

                            <!-- Action Buttons -->
                            <StackPanel Spacing="8">
                                <Button Command="{Binding Detail.ProcessAllCommand}"
                                        Background="#cba6f7" Foreground="#1e1e2e"
                                        CornerRadius="8" Padding="20,10" HorizontalAlignment="Left">
                                    <TextBlock Text="Smart Process" FontSize="13" FontWeight="SemiBold"/>
                                </Button>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button Command="{Binding Detail.TranscribeCommand}"
                                            IsEnabled="{Binding !Detail.IsBusy}"
                                            IsVisible="{Binding HasAudio}"
                                            Background="#89b4fa" Foreground="#1e1e2e"
                                            CornerRadius="6" Padding="14,6" FontSize="12"
                                            FontWeight="SemiBold">
                                        <TextBlock Text="Transcribe"/>
                                    </Button>
                                    <Button Command="{Binding Detail.IdentifySpeakersCommand}"
                                            IsEnabled="{Binding !Detail.IsBusy}"
                                            IsVisible="{Binding HasTranscript}"
                                            Background="#f9e2af" Foreground="#1e1e2e"
                                            CornerRadius="6" Padding="14,6" FontSize="12"
                                            FontWeight="SemiBold">
                                        <TextBlock Text="Identify Speakers"/>
                                    </Button>
                                    <Button Command="{Binding Detail.SummarizeCommand}"
                                            IsEnabled="{Binding !Detail.IsBusy}"
                                            IsVisible="{Binding HasTranscript}"
                                            Background="#a6e3a1" Foreground="#1e1e2e"
                                            CornerRadius="6" Padding="14,6" FontSize="12"
                                            FontWeight="SemiBold">
                                        <TextBlock Text="Summarize"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <!-- Tabs -->
                            <TabControl SelectedIndex="{Binding Detail.SelectedTabIndex}">
                                <TabControl.Styles>
                                    <Style Selector="TabItem">
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Foreground" Value="#cdd6f4"/>
                                        <Setter Property="Padding" Value="16,8"/>
                                    </Style>
                                </TabControl.Styles>

                                <TabItem Header="Transcript">
                                    <DockPanel Margin="0,12">
                                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" Spacing="4" Margin="0,0,0,8">
                                            <Button Command="{Binding Detail.ToggleOriginalTranscriptCommand}"
                                                    IsVisible="{Binding Detail.HasOriginalTranscript}"
                                                    Background="#45475a" Foreground="#cdd6f4"
                                                    CornerRadius="6" Padding="12,5" FontSize="12">
                                                <TextBlock Text="{Binding Detail.TranscriptViewLabel}"/>
                                            </Button>
                                            <Button Command="{Binding Detail.SaveTranscriptCommand}"
                                                    IsVisible="{Binding !Detail.ShowOriginalTranscript}"
                                                    Background="#cba6f7" Foreground="#1e1e2e"
                                                    CornerRadius="6" Padding="12,5" FontSize="12"
                                                    FontWeight="SemiBold">
                                                <TextBlock Text="Save"/>
                                            </Button>
                                            <Button Command="{Binding Detail.CopyTranscriptCommand}"
                                                    Background="#313244" Foreground="#bac2de"
                                                    CornerRadius="6" Padding="12,5" FontSize="12">
                                                <TextBlock Text="Copy"/>
                                            </Button>
                                            <Button Command="{Binding Detail.ExportTranscriptCommand}"
                                                    IsVisible="{Binding !Detail.ShowOriginalTranscript}"
                                                    Background="#313244" Foreground="#bac2de"
                                                    CornerRadius="6" Padding="12,5" FontSize="12">
                                                <TextBlock Text="Export"/>
                                            </Button>
                                        </StackPanel>
                                        <TextBox Text="{Binding Detail.OriginalTranscriptText}"
                                                 IsVisible="{Binding Detail.ShowOriginalTranscript}"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 Background="#1e1e2e" Foreground="#a6adc8"
                                                 CornerRadius="8" Padding="16"
                                                 MinHeight="250"/>
                                        <TextBox Text="{Binding Detail.TranscriptText}"
                                                 IsVisible="{Binding !Detail.ShowOriginalTranscript}"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 Background="#1e1e2e" Foreground="#cdd6f4"
                                                 CornerRadius="8" Padding="16"
                                                 Watermark="No transcript yet. Click 'Transcribe' to generate one."
                                                 MinHeight="250"/>
                                    </DockPanel>
                                </TabItem>

                                <TabItem Header="Summary">
                                    <DockPanel Margin="0,12">
                                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" Spacing="4" Margin="0,0,0,8">
                                            <Button Command="{Binding Detail.CopySummaryCommand}"
                                                    Background="#313244" Foreground="#bac2de"
                                                    CornerRadius="6" Padding="12,5" FontSize="12">
                                                <TextBlock Text="Copy"/>
                                            </Button>
                                            <Button Command="{Binding Detail.ExportSummaryCommand}"
                                                    Background="#313244" Foreground="#bac2de"
                                                    CornerRadius="6" Padding="12,5" FontSize="12">
                                                <TextBlock Text="Export"/>
                                            </Button>
                                        </StackPanel>
                                        <TextBox Text="{Binding Detail.SummaryText}"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 Background="#1e1e2e" Foreground="#cdd6f4"
                                                 CornerRadius="8" Padding="16"
                                                 Watermark="No summary yet. Transcribe first, then click 'Summarize'."
                                                 MinHeight="250"/>
                                    </DockPanel>
                                </TabItem>
                            </TabControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Panel>
        </Border>
    </Grid>
</UserControl>
